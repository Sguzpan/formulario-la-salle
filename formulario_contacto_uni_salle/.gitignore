# .gitignore

# Archivos de sistema y editores
.DS_Store
Thumbs.db
*.log
*.tmp
*.bak
.vscode/
.idea/

# Entorno local y credenciales sensibles
config.local.php
.env
vendor/
node_modules/

# Archivos generados o temporales
*.cache
*.min.js
*.min.css
build/
dist/

# XAMPP / PHP locales (no subas sesiones ni uploads temporales)
tmp/
session/
uploads/

# Base de datos (no subas dumps con datos reales)
*.sql.bak
db_backup.sql

# Ignorar el archivo de configuración con credenciales reales
# (usa config.example.php como plantilla)
Config/Database.php  # ← Si pones credenciales reales aquí, ignóralo
# Alternativa: mantén Database.php y crea .env (más profesional)

# Fin
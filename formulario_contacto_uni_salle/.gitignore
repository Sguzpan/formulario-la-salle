# --- Ignorar archivos sensibles y de configuración ---

# --- Entorno y Credenciales ---
.env
Config/config.local.php
Config/db_credentials.php 

# --- Archivos de Sistema y Editores ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log

# --- Dependencias y Temporales ---
vendor/
node_modules/
*.tmp
*.bak
tmp/
session/
uploads/

# --- Base de Datos ---
# Permite subir el schema.sql original, pero ignora backups con datos reales
database/*.sql.bak
database/dump_*.sql

# --- Pruebas locales ---
pruebas/prueba_bd.php